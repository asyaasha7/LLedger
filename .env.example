# Copy to `.env.local` and fill in values.

# --- Supabase Postgres (server-only) ---
# Dashboard → Project Settings → Database → Connection string (URI).
# Prefer "Session mode" pooler (port 5432) or direct connection; include sslmode=require.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase client (Auth / browser session) ---
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
# Publishable/anon key (Dashboard → API).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Or legacy name:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin for invite/magic-link redirects (production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only; Storage + auth admin — use only in Route Handlers / Server Actions.
SUPABASE_SERVICE_ROLE_KEY=

# AES-256 key for server-side evidence envelope encryption (32 bytes, base64).
# openssl rand -base64 32
EVIDENCE_ENCRYPTION_KEY=

# --- Hedera (all server-only except mirror URL / flag) ---
# When true AND operator env vars are set, new lease cases create an HCS topic
# and publish LEASE_CREATED (see bootstrap-hedera-new-case).
NEXT_PUBLIC_HEDERA_ENABLED=false
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_HEDERA_MIRROR_BASE=https://testnet.mirrornode.hedera.com
HEDERA_OPERATOR_ID=
# ECDSA testnet key often as `0x` + 64 hex chars; otherwise use SDK-supported formats.
HEDERA_OPERATOR_KEY=

# Bearer secret for POST /api/cron/hedera-outbox (retries pending HCS publishes).
CRON_SECRET=
